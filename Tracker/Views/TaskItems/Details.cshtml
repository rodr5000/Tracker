@model Tracker.Models.TaskItem

@{
    ViewData["Title"] = "Task Details";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="fw-bold mb-1">@Model.Title</h3>
                    <div class="text-muted small">
                        Main Task: <strong>@(Model.MainTask?.Name ?? "General")</strong>
                    </div>
                </div>

                <span class="badge
                    @(Model.Status == Tracker.Models.Enums.Status.Completed ? "bg-success" :
                                            Model.Status == Tracker.Models.Enums.Status.InProgress ? "bg-primary" :
                                            Model.Status == Tracker.Models.Enums.Status.Cancelled ? "bg-danger" :
                                            "bg-secondary")">
                    @Model.Status
                </span>
            </div>

            <div class="mt-2">
                @if (Model.TaskItemTags != null && Model.TaskItemTags.Any())
                {
                    @foreach (var itemTag in Model.TaskItemTags)
                    {
                        @if (itemTag.Tag != null)
                        {
                            <span class="badge bg-primary px-2.5 py-1.5 me-1 shadow-sm fs-7">
                                <i class="bi bi-tag-fill me-1"></i> @itemTag.Tag.Name
                            </span>
                        }
                    }
                }
                else
                {
                    <span class="text-muted small italic"><i class="bi bi-tag"></i> No tags</span>
                }
            </div>

            <hr />

            <p class="text-muted">
                @(string.IsNullOrWhiteSpace(Model.Description)
                                ? "No description provided."
                                : Model.Description)
            </p>

            <div class="row mt-3">

                <div class="col-md-4">
                    <div class="small text-muted">Priority</div>
                    <span class="badge
                        @(Model.Priority == Tracker.Models.Enums.Priority.High ? "bg-danger" :
                                                    Model.Priority == Tracker.Models.Enums.Priority.Medium ? "bg-warning text-dark" :
                                                    "bg-secondary")">
                        @Model.Priority
                    </span>
                </div>

                <div class="col-md-4">
                    <div class="small text-muted">Start Date</div>
                    <div>@(Model.StartDate?.ToString("dd MMM yyyy") ?? "—")</div>
                </div>

                <div class="col-md-4">
                    <div class="small text-muted">Due Date</div>
                    <div>@(Model.DueDate?.ToString("dd MMM yyyy") ?? "—")</div>
                </div>

            </div>

            <hr />

            <div class="row">

                <div class="col-md-4">
                    <div class="small text-muted">Estimated Time</div>
                    <div>
                        @(Model.EstimatedTime?.ToString(@"hh\:mm") ?? "—")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="small text-muted">Time Taken</div>
                    <div>
                        @(Model.TimeTaken?.ToString(@"hh\:mm") ?? "—")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="small text-muted">Progress</div>

                    <div class="progress mt-1" style="height: 8px;">
                        <div class="progress-bar
                            @(Model.ProgressPercentage > 80 ? "bg-success" :
                                                           Model.ProgressPercentage > 40 ? "bg-warning" :
                                                           "bg-danger")"
                             style="width: @Model.ProgressPercentage%">
                        </div>
                    </div>

                    <div class="small text-muted mt-1">
                        @Model.ProgressPercentage.ToString("0")%
                    </div>
                </div>

            </div>

            <hr />

            <div class="d-flex gap-2">

                <a class="btn btn-warning"
                       asp-action="Edit"
                       asp-route-id="@Model.Id">
                    ✏️ Edit
                </a>

                <a class="btn btn-danger"
                       asp-action="Delete"
                       asp-route-id="@Model.Id">
                    🗑 Delete
                </a>

                <a class="btn btn-outline-secondary"
                       asp-action="Index">
                    ← Back
                </a>

            </div>

        </div>
    </div>
</div>