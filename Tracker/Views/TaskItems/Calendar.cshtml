@{
    ViewData["Title"] = "Calendar";
}

<div id="calendar"></div>

@section Scripts {
    <script>
               document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('calendar');

        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            height: "auto",
            selectable: true,
            editable: true,
            eventDisplay: 'block',
            displayEventTime: false,
            dayMaxEvents: true,
            

            events: '/TaskItems/GetCalendarEvents',

            select: function (info) {
                window.location.href =
                    `/TaskItems/Create?start=${info.startStr}&end=${info.endStr}`;
            },

           eventClick: function (info) {
               const realId = info.event.extendedProps.taskId; // ✅
               window.location.href = `/TaskItems/Edit/${realId}`;
        },

                eventDrop: function (info) {
                    updateTaskTime(info.event);
                },

                eventResize: function (info) {
                    updateTaskTime(info.event);
                },

           eventDidMount: function(info) {
            const tooltip = `
                <strong>${info.event.title}</strong><br/>
                Status: ${info.event.extendedProps.status || ''}<br/>
                Priority: ${info.event.extendedProps.priority || ''}
            `;

            info.el.setAttribute("title", tooltip);
        }
            });

            calendar.render();
        });

        function toLocalDateTimeString(date) {
            return date.getFullYear() + "-" +
                String(date.getMonth() + 1).padStart(2, '0') + "-" +
                String(date.getDate()).padStart(2, '0') + "T" +
                String(date.getHours()).padStart(2, '0') + ":" +
                String(date.getMinutes()).padStart(2, '0') + ":00";
        }

        function updateTaskTime(event) {
            fetch('/TaskItems/UpdateTime', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    id: event.id,
                    startTime: toLocalDateTimeString(event.start),
                    endTime: toLocalDateTimeString(event.end)
                })
            });
        }



    </script>
}
