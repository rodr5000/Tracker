@model Tracker.Models.TaskItem

@{
    ViewData["Title"] = "Delete Task";
}

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- Header -->
                <div class="bg-danger text-white p-4">
                    <h2 class="mb-1">⚠ Delete Task</h2>
                    <p class="mb-0">This action cannot be undone.</p>
                </div>

                <div class="card-body p-4">

                    <!-- Confirmation Text -->
                    <div class="text-center mb-4">
                        <h4 class="fw-bold">Are you sure?</h4>
                        <p class="text-muted">
                            You are about to permanently delete this task.
                        </p>
                    </div>

                    <!-- Task Preview -->
                    <div class="card border-0 shadow-sm rounded-4 mb-4">
                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-center">
                                <h4 class="fw-bold mb-0">@Model.Title</h4>

                                <span class="badge
                                    @(Model.Status == Tracker.Models.Enums.Status.Completed ? "bg-success" :
                                                                            Model.Status == Tracker.Models.Enums.Status.InProgress ? "bg-primary" :
                                                                            Model.Status == Tracker.Models.Enums.Status.Cancelled ? "bg-danger" :
                                                                            "bg-secondary")">
                                    @Model.Status
                                </span>
                            </div>

                            <p class="text-muted mt-2">
                                @(string.IsNullOrWhiteSpace(Model.Description)
                                    ? "No description provided."
                                    : Model.Description)
                            </p>

                            <div class="row mt-3">

                                <div class="col-md-4">
                                    <small class="text-muted">Priority</small><br />
                                    <span class="badge
                                        @(Model.Priority == Tracker.Models.Enums.Priority.High ? "bg-danger" :
                                                                                    Model.Priority == Tracker.Models.Enums.Priority.Medium ? "bg-warning text-dark" :
                                                                                    "bg-secondary")">
                                        @Model.Priority
                                    </span>
                                </div>

                                <div class="col-md-4">
                                    <small class="text-muted">Start Date</small><br />
                                    @(Model.StartDate?.ToString("dd MMM yyyy") ?? "—")
                                </div>

                                <div class="col-md-4">
                                    <small class="text-muted">Due Date</small><br />
                                    @(Model.DueDate?.ToString("dd MMM yyyy") ?? "—")
                                </div>

                            </div>

                        </div>
                    </div>

                    <!-- Buttons -->
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex justify-content-center gap-3">

                            <button type="submit" class="btn btn-danger px-4">
                                🗑 Yes, Delete
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                Cancel
                            </a>

                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>

</div>