@using Tracker.Models.Enums
@model IEnumerable<Tracker.Models.TaskItem>

@{
    ViewData["Title"] = "Tasks";
}



<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">My Tasks</h2>
        <a class="expand-btn primary" asp-action="Create">+ Add Task</a>
    </div>

    <div class="list-group">
        @foreach (var task in Model)
        {
            var statusClass = task.Status switch
            {
                Status.Pending => "bg-pending",
                Status.InProgress => "bg-inprogress",
                Status.Completed => "bg-completed",
                Status.Cancelled => "bg-cancelled",
                _ => ""
            };

            <div class="list-group-item list-group-item-action mb-2 rounded shadow-sm task-card @statusClass"
            style="border-left-width: 10px;">


                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="mt-2">

                            @if (task.IsWorking)
                            {
                                <form asp-action="StopWork" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <button class="expand-btn danger">
                                        ⏹ Stop
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="StartWork" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <button class="expand-btn success">
                                        ▶ Start
                                    </button>
                                </form>
                            }

                        </div>



                        <!-- ✅ Clickable title only -->
                        <h5 class="mb-1">
                            <a asp-action="Details"
                            asp-route-id="@task.Id"
                            class="text-decoration-none text-dark">
                                @task.Title
                            </a>
                        </h5>

                        <div class="small text-muted">
                            Priority: <strong>@task.Priority</strong>
                        </div>

                        @if (!string.IsNullOrEmpty(task.Description))
                        {
                            <p class="mt-2 text-secondary">@task.Description</p>
                        }
                    </div>

                    <!-- ✅ INLINE STATUS CHANGE -->
                    <div class="text-end">
                        <form asp-action="UpdateStatus" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@task.Id" />

                            <select name="status"
                            class="form-select form-select-sm"
                            onchange="this.form.submit()">
                                @foreach (Status s in Enum.GetValues(typeof(Status)))
                                {
                                    <option value="@s" selected="@(s == task.Status)">
                                        @s
                                    </option>

                                }
                            </select>
                        </form>
                    </div> 
                </div>
                <div class="mt-2">

                    @foreach (var tag in task.TaskItemTags)
                    {
                        <span class="badge bg-primary me-1">
                            @tag.Tag.Name
                        </span>
                    }

                </div>
                @if (task.DueDate.HasValue)
                {
                    <div class="small mt-2 text-end text-muted">
                        Due: @task.DueDate.Value.ToString("dd MMM yyyy")
                    </div>
                }
                @if (task.TimeTaken.HasValue)
                {
                    <span class="text-muted">
                        Time taken: @task.TimeTaken.Value.ToString(@"hh\:mm\:ss")
                    </span>
                }
                else
                {
                    <span class="text-muted">
                        Time taken: --
                    </span>
                }
                @if (task.EstimatedTime.HasValue)
                {
                    <div class="mt-2">
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar"
                                 role="progressbar"
                                 style="width: @task.ProgressPercentage%"
                                 aria-valuenow="@task.ProgressPercentage"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                            </div>
                        </div>

                        <div class="small text-muted mt-1">
                            @task.TimeTaken?.ToString(@"hh\:mm") /
                            @task.EstimatedTime?.ToString(@"hh\:mm")
                            (@Math.Round(task.ProgressPercentage)%)
                        </div>
                    </div>
                }

            </div>
        }
    </div>



</div>

<a class="expand-btn dark" asp-action="Report" asp-route-filter="overdue">
    📊 Report
</a>


        


