@model Tracker.Models.MainTask

@{
    ViewData["Title"] = "Edit Main Task";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body">
            <h2 class="fw-bold mb-4">✏ Edit Main Task</h2>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Name</label>
                    <input asp-for="Name" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Due Date</label>
                        <input asp-for="DueDate" type="datetime-local" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-semibold">Hours</label>
                        <input type="number" name="Hours" class="form-control" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-semibold">Minutes</label>
                        <input type="number" name="Minutes" class="form-control" />
                    </div>
                </div>

                <button type="submit" class="btn btn-success">💾 Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>