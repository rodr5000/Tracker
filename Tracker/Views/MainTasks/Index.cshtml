@model IEnumerable<Tracker.Models.MainTask>

@{
    ViewData["Title"] = "Main Tasks";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Main Tasks</h2>
        <a class="btn btn-primary expand-btn primary" asp-action="Create">
            ➕ Create Main Task
        </a>
    </div>

    <div class="list-group">
        @foreach (var item in Model)
        {
            <a asp-action="Details"
               asp-route-id="@item.Id"
               class="main-task-link">

                <div class="list-group-item list-group-item-action mb-3 rounded shadow-sm main-task-card">

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            @if (!string.IsNullOrEmpty(item.Name))
                            {
                                <p class="text-decoration-none text-bg-dark">@item.Name</p>
                            }
                        </div>

                        <div class="text-end">
                            <span class="badge bg-light text-muted">Click for details →</span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <div class="small text-muted">
                            Created: @item.CreatedAt?.ToString("dd MMM yyyy")
                        </div>

                        @if (item.DueDate.HasValue)
                        {
                            <div class="small text-muted">
                                Due: @item.DueDate.Value.ToString("dd MMM yyyy")
                            </div>
                        }
                        @if (item.Duration.HasValue)
                        {
                            <div class="small text-muted">
                                Duration: @((int)item.Duration.Value.TotalHours):@item.Duration.Value.Minutes.ToString("00"):@item.Duration.Value.Seconds.ToString("00")

                            </div>
                        }
                    </div>

                    <div class="mt-3 d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-primary expand-btn primary">
                            Edit
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-danger expand-btn danger">
                            Delete
                        </a>
                    </div>

                </div>
            </a>
        }
    </div>
</div>
