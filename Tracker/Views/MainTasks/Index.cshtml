@model IEnumerable<Tracker.Models.MainTask>

@{
    ViewData["Title"] = "Main Tasks";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Main Tasks</h2>
        <a class="btn btn-primary" asp-action="Create">➕ Create Main Task</a>
    </div>

    <div class="list-group">
        @foreach (var item in Model)
        {
            <div class="list-group-item mb-3 rounded shadow-sm main-task-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0">@item.Name</h5>
                    </div>
                    <div class="text-end">
                        <button class="btn btn-sm btn-info" onclick="toggleTasks(@item.Id)">
                            View Task Items (@(item.TaskItems?.Count() ?? 0))
                        </button>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-3 small text-muted">
                    <div>Created: @item.CreatedAt?.ToString("dd MMM yyyy")</div>
                    @if (item.DueDate.HasValue)
                    {
                        <div>Due: @item.DueDate.Value.ToString("dd MMM yyyy")</div>
                    }
                    @if (item.Duration.HasValue)
                    {
                        <div>Duration Hours: @((int)item.Duration.Value.TotalHours):@item.Duration.Value.Minutes.ToString("00")</div>
                    }
                </div>

                <div id="tasks-@item.Id" style="display:none;" class="mt-3 border-top pt-2">
                    <div class="list-group list-group-flush">
                        @if (item.TaskItems != null && item.TaskItems.Any())
                        {
                            @foreach (var subTask in item.TaskItems)
                            {
                                <a asp-controller="TaskItems"
                                   asp-action="Details"
                                   asp-route-id="@subTask.Id"
                                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2 bg-light border-0 mb-1 rounded">

                                    <span>
                                        <i class="bi bi-check2-square me-2"></i> @subTask.Title
                                    </span>

                                    <span class="badge bg-secondary rounded-pill">
                                        @subTask.TimeTaken mins
                                    </span>
                                </a>
                            }
                        }
                        @* Inside your toggle div *@
                        <div id="tasks-@item.Id" style="display:none;" class="mt-3 border-top pt-2">
                            <div class="d-flex justify-content-between align-items-center mb-2 px-2">
                                <h6 class="mb-0 text-secondary">Sub-Tasks</h6>
                                @* Quick link to add a task item to THIS specific main task *@
                                <a asp-controller="TaskItems" asp-action="Create" asp-route-mainTaskId="@item.Id" class="btn btn-sm btn-link p-0">+ Add Item</a>
                            </div>

                            <div class="list-group list-group-flush">
                                @if (item.TaskItems != null && item.TaskItems.Any())
                                {
                                    @foreach (var subTask in item.TaskItems)
                                    {
                                        <a asp-controller="TaskItems" asp-action="Details" asp-route-id="@subTask.Id"
                                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2 bg-light border-0 mb-1 rounded">
                                            <span>
                                                <i class="bi bi-circle me-2 text-primary"></i> @subTask.Title
                                            </span>
                                            <span class="badge bg-secondary rounded-pill">
                                                @subTask.TimeTaken mins
                                            </span>
                                        </a>
                                    }
                                }
                               else
                                {
                                    <div class="ps-3 text-muted small py-2">
                                        No tasks assigned yet. <a asp-controller="TaskItems" asp-action="Create" asp-route-mainTaskId="@item.Id">Create one?</a>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </div>
        }
    </div>
</div>

<script>
    function toggleTasks(id) {
        const element = document.getElementById("tasks-" + id);
        element.style.display = (element.style.display === "none") ? "block" : "none";
    }

</script>