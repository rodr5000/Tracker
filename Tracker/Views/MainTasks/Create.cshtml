@model Tracker.Models.MainTask

@{
    ViewData["Title"] = "Create Main Task";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body">
            <h2 class="fw-bold mb-4">📁 Create Main Task</h2>

            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Project / Main Task Name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" rows="4" class="form-control"
                              placeholder="Describe this project..."></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Due Date</label>
                        <input asp-for="DueDate" type="datetime-local" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Estimated Duration (hours)</label>
                        <input type="number" name="DurationHours" step="0.5" class="form-control" />
                    </div>
                </div>

                <button type="submit" class="btn btn-success">➕ Create</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>