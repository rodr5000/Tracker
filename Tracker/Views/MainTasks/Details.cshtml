@model Tracker.Models.MainTask

@{
    ViewData["Title"] = "Main Task Details";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body">
            <h2 class="fw-bold">@Model.Name</h2>
            <p class="text-muted">@Model.Description</p>

            <hr />

            <div class="row">
                <div class="col-md-4">
                    <small class="text-muted">Created At</small><br />
                    @Model.CreatedAt?.ToString("dd MMM yyyy")
                </div>

                <div class="col-md-4">
                    <small class="text-muted">Due Date</small><br />
                    @Model.DueDate?.ToString("dd MMM yyyy")
                </div>

                <div class="col-md-4">
                    <small class="text-muted">Remaining Duration</small><br />
                    @(Model.Duration?.ToString(@"hh\:mm") ?? "—")
                </div>
            </div>

            <hr />

            <h5>📋 Tasks Under This Project</h5>

            @if (Model.TaskItems != null && Model.TaskItems.Any())
            {
                <ul class="list-group mt-3">
                    @foreach (var task in Model.TaskItems)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            @task.Title
                            <span class="badge bg-secondary">@task.Status</span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No tasks yet.</p>
            }

            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">✏ Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">🗑 Delete</a>
                <a asp-action="Index" class="btn btn-outline-secondary">⬅ Back</a>
            </div>
        </div>
    </div>
</div>