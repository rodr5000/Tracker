@model Tracker.Models.TaskItem

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-body">

            <h3 class="mb-3">📋 Task Details</h3>

            <h4 class="text-primary">@Model.Title</h4>

            <hr />

            <p><strong>Description:</strong></p>
            <p class="text-muted">@Model.Description</p>

            <hr />

            <div class="row">
                <div class="col-md-6">
                    <p><strong>Status:</strong> @Model.Status</p>
                    <p><strong>Priority:</strong> @Model.Priority</p>
                    <p><strong>User:</strong> @Model.User?.Email</p>
                </div>

                <div class="col-md-6">
                    <p><strong>Start Date:</strong> @Model.StartDate?.ToString("dd MMM yyyy")</p>
                    <p><strong>Due Date:</strong> @Model.DueDate?.ToString("dd MMM yyyy")</p>
                </div>
            </div>

            <hr />

            <div class="row">
                <div class="col-md-4">
                    <p>
                        <strong>Estimated Time:</strong><br />
                        @(Model.EstimatedTime?.ToString(@"hh\:mm") ?? "—")
                    </p>
                </div>

                <div class="col-md-4">
                    <p>
                        <strong>Time Taken:</strong><br />
                        @(Model.TimeTaken?.ToString(@"hh\:mm") ?? "—")
                    </p>
                </div>

                <div class="col-md-4">
                    <p><strong>Progress:</strong></p>
                    <div class="progress">
                        <div class="progress-bar"
                             role="progressbar"
                             style="width: @Model.ProgressPercentage%">
                            @Model.ProgressPercentage.ToString("0")%
                        </div>
                    </div>
                </div>
            </div>

            <hr />

            <a asp-action="UserTasks"
               asp-route-userId="@Model.UserId"
               class="btn btn-secondary">
                🔙 Back
            </a>

        </div>
    </div>
</div>