@model Tracker.Models.Tag

<div class="container mt-4">
    <div class="card shadow p-4">

        <h2>Create Tag</h2>

        <form asp-action="Create">

            <div class="mb-3">
                <label class="form-label">Tag Name</label>

                <input asp-for="Name"
                       class="form-control" />
            </div>

            <button class="btn btn-primary">
                Create
            </button>

        </form>

    </div>
</div>